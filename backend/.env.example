PORT=3000
SWAGGER_PATH=docs

# Option 1: use a single database connection string.
# DATABASE_URL=postgresql://your_database_user:your_database_password@localhost:5432/your_database_name

# Option 2: use separate database variables.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_DATABASE=your_database_name

DB_SYNC=true

# Frontend origins that can receive credentials. Comma-separated for multiple portals.
FRONTEND_URL=http://localhost:3001,http://localhost:3002

# Comma-separated emails that should automatically receive SUPER_ADMIN role.
SUPER_ADMIN_EMAILS=owner@example.com

# JWT secrets must be long, random, and different per environment.
JWT_ACCESS_SECRET=replace_with_at_least_32_random_chars_access
JWT_REFRESH_SECRET=replace_with_at_least_32_random_chars_refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Cookie policy: lax for same-site local dev, none only for HTTPS cross-site deployments.
COOKIE_SAME_SITE=lax

# OAuth providers are optional. Fill these to enable /api/auth/login/google and /api/auth/login/facebook.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/login/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/login/facebook/callback
